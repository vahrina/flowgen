<UserControl x:Class="Flow.Launcher.Plugin.PassGen.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="420"
             PreviewMouseWheel="OnPreviewMouseWheel"
             RequestBringIntoView="OnRequestBringIntoView">

    <UserControl.Resources>
        <Style x:Key="SectionHeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                CornerRadius="9"
                                Background="#3A3A3A"
                                BorderBrush="#6A6A6A"
                                BorderThickness="1">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="#EAEAEA"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GroupHeaderTemplate">
            <DockPanel LastChildFill="False" VerticalAlignment="Center">
                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}, Path=Header}"
                           Style="{StaticResource SectionHeaderTextStyle}"/>
                <Button Style="{StaticResource InfoButtonStyle}"
                        Content="i"
                        ToolTip="{Binding RelativeSource={RelativeSource AncestorType=GroupBox}, Path=Tag}"
                        ToolTipService.InitialShowDelay="0"
                        ToolTipService.ShowDuration="60000"/>
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Changes are saved automatically."
                   Margin="0,0,0,8"
                   Foreground="#888"/>

        <Grid x:Name="LayoutGrid" Grid.Row="1" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="Col0" Width="1.7*"/>
                <ColumnDefinition x:Name="Col1" Width="1.15*"/>
                <ColumnDefinition x:Name="Col2" Width="1.15*"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="ColA" Grid.Column="0" Margin="6,0,6,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" ClipToBounds="True">
                <GroupBox x:Name="SymbolsGroup"
                          Header="Symbols"
                          HeaderTemplate="{StaticResource GroupHeaderTemplate}"
                          Tag="Choose which symbols can be used in generated passwords. Use the buttons to quickly toggle sets."
                          Margin="0,0,0,6"
                          HorizontalAlignment="Stretch">
                    <GroupBox.Template>
                        <ControlTemplate TargetType="GroupBox">
                            <Border CornerRadius="10"
                                    BorderThickness="3"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ContentPresenter Grid.Row="0"
                                                      ContentSource="Header"
                                                      Margin="0,0,0,8"/>

                                    <ContentPresenter Grid.Row="1"
                                                      ContentSource="Content"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </GroupBox.Template>

                    <StackPanel Margin="10">
                        <WrapPanel Margin="0,0,0,10">
                            <Border CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,14,8">
                                <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                    <Button x:Name="SymbolsRecommendedBtn" Content="Recommended" Width="120"/>
                                    <Button Style="{StaticResource InfoButtonStyle}"
                                            Content="i"
                                            ToolTip="Select a curated set of symbols that is usually accepted by most services."
                                            ToolTipService.InitialShowDelay="0"
                                            ToolTipService.ShowDuration="60000"/>
                                </DockPanel>
                            </Border>

                            <Border CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,14,8">
                                <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                    <Button x:Name="SymbolsSelectAllBtn" Content="Select all" Width="120"/>
                                    <Button Style="{StaticResource InfoButtonStyle}"
                                            Content="i"
                                            ToolTip="Enable all symbols in the list."
                                            ToolTipService.InitialShowDelay="0"
                                            ToolTipService.ShowDuration="60000"/>
                                </DockPanel>
                            </Border>

                            <Border CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,0,8">
                                <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                    <Button x:Name="SymbolsClearAllBtn" Content="Clear all" Width="120"/>
                                    <Button Style="{StaticResource InfoButtonStyle}"
                                            Content="i"
                                            ToolTip="Disable all symbols in the list."
                                            ToolTipService.InitialShowDelay="0"
                                            ToolTipService.ShowDuration="60000"/>
                                </DockPanel>
                            </Border>
                        </WrapPanel>

                        <UniformGrid x:Name="SymbolsGrid" Columns="7">
                            <UniformGrid.Resources>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="ContentTemplate">
                                        <Setter.Value>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=CheckBox}, Path=Foreground}"/>
                                            </DataTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </UniformGrid.Resources>

                            <CheckBox x:Name="SymExclam" Content="!" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymAt" Content="@" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymHash" Content="#" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymDollar" Content="$" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymPercent" Content="%" Margin="0,0,14,10"/>

                            <CheckBox x:Name="SymUnderscore" Content="_" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymDash" Content="-" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymDot" Content="." Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymComma" Content="," Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymColon" Content=":" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymSemicolon" Content=";" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymPlus" Content="+" Margin="0,0,14,10"/>

                            <CheckBox x:Name="SymEquals" Content="=" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymAmpersand" Content="&amp;" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymAsterisk" Content="*" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymCaret" Content="^" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymQuestion" Content="?" Margin="0,0,14,10"/>

                            <CheckBox x:Name="SymOpenParen" Content="(" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymCloseParen" Content=")" Margin="0,0,14,10"/>

                            <CheckBox x:Name="SymSlash" Content="/" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymOpenBracket" Content="[" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymCloseBracket" Content="]" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymOpenBrace" Content="{}{" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymCloseBrace" Content="{}}" Margin="0,0,14,10"/>

                            <CheckBox x:Name="SymTilde" Content="~" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymBacktick" Content="`" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymBackslash" Content="&#92;" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymPipe" Content="|" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymLessThan" Content="&lt;" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymGreaterThan" Content="&gt;" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymApostrophe" Content="'" Margin="0,0,14,10"/>
                            <CheckBox x:Name="SymQuote" Content="&quot;" Margin="0,0,14,10"/>
                        </UniformGrid>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <StackPanel x:Name="ColB" Grid.Column="1" Margin="8,0,6,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" ClipToBounds="True">
                <GroupBox Header="General"
                          HeaderTemplate="{StaticResource GroupHeaderTemplate}"
                          Tag="Controls password length and digits. Fixed uses one length. Random picks a new length on each generation between Min and Max. Allowed range is 4-100."
                          Margin="0,0,0,14"
                          HorizontalAlignment="Stretch">
                    <GroupBox.Template>
                        <ControlTemplate TargetType="GroupBox">
                            <Border CornerRadius="10"
                                    BorderThickness="3"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ContentPresenter Grid.Row="0"
                                                      ContentSource="Header"
                                                      Margin="0,0,0,8"/>

                                    <ContentPresenter Grid.Row="1"
                                                      ContentSource="Content"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </GroupBox.Template>

                    <StackPanel Margin="10">
                        <TextBlock Text="Length mode" Margin="0,0,0,6"/>

                        <WrapPanel Margin="0,0,0,10">
                            <Border CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,14,8">
                                <RadioButton x:Name="LenFixedRadio"
                                             GroupName="LengthMode"
                                             Content="Fixed"
                                             VerticalAlignment="Center"/>
                            </Border>

                            <Border CornerRadius="8"
                                    BorderThickness="2"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="14,8"
                                    Margin="0,0,0,8">
                                <RadioButton x:Name="LenRandomRadio"
                                             GroupName="LengthMode"
                                             Content="Random"
                                             VerticalAlignment="Center"/>
                            </Border>
                        </WrapPanel>

                        <StackPanel x:Name="FixedLengthPanel" Margin="0,0,0,10">
                            <WrapPanel>
                                <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" Text="Length (4-100):" Margin="0,0,8,0"/>
                                    <TextBox x:Name="DefaultLengthBox" Width="72" HorizontalAlignment="Left"/>
                                </DockPanel>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel x:Name="RandomLengthPanel" Margin="0,0,0,10">
                            <WrapPanel>
                                <DockPanel LastChildFill="False" Margin="0,0,14,8">
                                    <TextBlock VerticalAlignment="Center" Text="Min (4-100):" Margin="0,0,8,0"/>
                                    <TextBox x:Name="MinLengthBox" Width="72" HorizontalAlignment="Left"/>
                                </DockPanel>

                                <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" Text="Max (4-100):" Margin="0,0,8,0"/>
                                    <TextBox x:Name="MaxLengthBox" Width="72" HorizontalAlignment="Left"/>
                                </DockPanel>
                            </WrapPanel>
                        </StackPanel>

                        <CheckBox x:Name="IncludeDigitsBox" Content="Include digits (0-9)"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Letters"
                          HeaderTemplate="{StaticResource GroupHeaderTemplate}"
                          Tag="Controls which letter cases are allowed in generated passwords."
                          Margin="0,0,0,6"
                          HorizontalAlignment="Stretch">
                    <GroupBox.Template>
                        <ControlTemplate TargetType="GroupBox">
                            <Border CornerRadius="10"
                                    BorderThickness="3"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ContentPresenter Grid.Row="0"
                                                      ContentSource="Header"
                                                      Margin="0,0,0,8"/>

                                    <ContentPresenter Grid.Row="1"
                                                      ContentSource="Content"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </GroupBox.Template>

                    <StackPanel Margin="10">
                        <StackPanel>
                            <RadioButton x:Name="LowerOnlyRadio" Content="Only lower-case (a-z)" GroupName="LetterMode"/>
                            <RadioButton x:Name="UpperOnlyRadio" Content="Only UPPER-case (A-Z)" GroupName="LetterMode"/>
                            <RadioButton x:Name="BothRadio" Content="Lower and UPPER (a-z + A-Z)" GroupName="LetterMode"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <StackPanel x:Name="ColBExtra"/>
            </StackPanel>

            <StackPanel x:Name="ColCPanel" Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Top" HorizontalAlignment="Stretch" ClipToBounds="True">
                <GroupBox x:Name="EnterActionGroup"
                          Header="Enter action"
                          HeaderTemplate="{StaticResource GroupHeaderTemplate}"
                          Tag="Choose what happens when you press Enter: Copy will copy the result. Copy and Paste will copy it and then paste using Ctrl+V."
                          Margin="0,0,0,6"
                          HorizontalAlignment="Stretch">
                    <GroupBox.Template>
                        <ControlTemplate TargetType="GroupBox">
                            <Border CornerRadius="10"
                                    BorderThickness="3"
                                    BorderBrush="#5A5A5A"
                                    Background="Transparent"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <ContentPresenter Grid.Row="0"
                                                      ContentSource="Header"
                                                      Margin="0,0,0,8"/>

                                    <ContentPresenter Grid.Row="1"
                                                      ContentSource="Content"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </GroupBox.Template>

                    <StackPanel Margin="10">
                        <RadioButton x:Name="ActionCopyRadio" Content="Copy" GroupName="EnterAction" Margin="0,0,0,6"/>
                        <RadioButton x:Name="ActionCopyPasteRadio" Content="Copy and Paste" GroupName="EnterAction"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>
